# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Auth (Google OAuth via NextAuth) ─────────────────────────────────────────
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://your-domain.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── Financial data ───────────────────────────────────────────────────────────
FMP_API_KEY=your_fmp_api_key_here
FRED_API_KEY=your_fred_api_key_here

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here

# ─── Payments (PayPal) ────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# ─── Cron job protection ──────────────────────────────────────────────────────
# Must be set — cron routes return 401 if missing (fail-closed)
CRON_SECRET=your_cron_secret_here

# ─── Social post automation (GitHub Actions dispatch) ─────────────────────────
GH_DISPATCH_TOKEN=your_github_pat_here
GH_REPO=your-github-username/your-repo-name

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated list of admin email addresses (server-side only, no NEXT_PUBLIC)
ADMIN_EMAILS=admin@yourdomain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com
AUDIT_DEV_KEY=your_audit_dev_key_here

# ─── AI (Google Gemini — used for social post generation) ─────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Feature flags ────────────────────────────────────────────────────────────
# Set to "true" only in local dev to bypass Pro gates for testing
# NEXT_PUBLIC_BETA_MODE=false

# Resend audience sync — get audience ID from resend.com/audiences
RESEND_AUDIENCE_ID=your_resend_audience_id_here
